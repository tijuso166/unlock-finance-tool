# Database
DATABASE_URL=postgresql://festivalfinance:festivalfinance@localhost:5432/festivalfinance

# Auth passwords (shared, no individual accounts)
MEMBER_PASSWORD=change_me_member
TREASURER_PASSWORD=change_me_treasurer

# Session secret (min 32 random characters!)
SESSION_SECRET=change_me_to_a_long_random_string_minimum_32_chars

# Festival year for filtering
FESTIVAL_YEAR=2025

# Base path (must match next.config.js basePath)
NEXT_PUBLIC_BASE_PATH=/finanzen
